PORT=8001

# Must exactly match server/.env
AI_SERVICE_TOKEN=PASTE_NEW_INTERNAL_SERVICE_TOKEN

# Use only one provider
OPENROUTER_API_KEY=PASTE_NEW_PERSONAL_OPENROUTER_KEY
OPENAI_API_KEY=

# Leave blank to select OpenRouter or OpenAI from the key above
AI_BASE_URL=
AI_MODEL=anthropic/claude-sonnet-4.6
AI_TIMEOUT_SECONDS=60

# Only Express can call the AI service
CORS_ORIGINS=http://localhost:8000
