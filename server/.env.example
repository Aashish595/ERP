NODE_ENV=development
PORT=8000

# Copy a NEW Supabase Session Pooler URL from the Supabase Connect panel
DATABASE_URL=postgresql://postgres.PROJECT_REF:URL_ENCODED_NEW_PASSWORD@SESSION_POOLER_HOST:5432/postgres
DATABASE_SSL=true
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_STATEMENT_TIMEOUT_MS=15000

# Optional for now
REDIS_URL=
REDIS_REQUIRED=false

# Generate completely new values
JWT_SECRET=PASTE_NEW_64_BYTE_RANDOM_VALUE
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=15
REFRESH_TOKEN_COOKIE_NAME=erp_refresh_token
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FRONTEND_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:8000

# Google OAuth web client. Leave blank to disable Google sign-in.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8000/auth/google/callback

# Docker Compose overrides this with http://ai-service:8001
AI_SERVICE_URL=http://localhost:8001
AI_SERVICE_TOKEN=PASTE_NEW_INTERNAL_SERVICE_TOKEN

# Start with debug mode, then change to false after testing SMTP
EMAIL_OTP_DEBUG=true
OTP_EXPIRE_MINUTES=10
OTP_MAX_ATTEMPTS=5

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=YOUR_PERSONAL_SMTP_EMAIL
SMTP_PASSWORD=YOUR_NEW_GMAIL_APP_PASSWORD
SMTP_FROM_EMAIL=YOUR_PERSONAL_SMTP_EMAIL
SMTP_FROM_NAME=School ERP
SMTP_USE_TLS=true

# Optional personal Cloudinary credentials
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Optional personal/authorized BBB server
BBB_URL=
BBB_SECRET=
BBB_TIMEOUT_MS=15000
BBB_CHECKSUM_ALGORITHM=sha1

# Optional AI answer sharing
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=
