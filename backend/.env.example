SECRET_KEY=replace-with-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

DATABASE_URL=postgresql://erp_user:erp_password@localhost:5432/erp_db
ASYNC_DATABASE_URL=postgresql+asyncpg://erp_user:erp_password@localhost:5432/erp_db
REDIS_URL=redis://localhost:6379/0

# Persistent API processes should keep a small bounded database pool. Set
# DB_USE_NULL_POOL=true only for short-lived/serverless jobs. When using a
# transaction-mode PgBouncer/Supabase pooler, set the prepared statement cache
# size to 0 if your pooler configuration does not support prepared statements.
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800
DB_CONNECT_TIMEOUT_SECONDS=10
DB_COMMAND_TIMEOUT_SECONDS=30
DB_USE_NULL_POOL=false
DB_ASYNCPG_PREPARED_STATEMENT_CACHE_SIZE=100
DB_SLOW_QUERY_MS=500
REDIS_REQUIRED=false

BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FRONTEND_BASE_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

RUN_STARTUP_MIGRATIONS=false
API_SLOW_LOG_MS=1000
REFRESH_TOKEN_COOKIE_SECURE=false
REFRESH_TOKEN_COOKIE_SAMESITE=lax
REFRESH_TOKEN_COOKIE_DOMAIN=
REFRESH_TOKEN_COOKIE_PATH=/auth

OPENROUTER_API_KEY=
OPENAI_API_KEY=
MODEL=anthropic/claude-sonnet-4.6
TRANSCRIPTION_MODEL=whisper-1
EMBEDDING_MODEL=text-embedding-3-small
TAVILY_API_KEY=
BBB_URL=https://tensordock-bbb.freedynamicdns.net/bigbluebutton/api
BBB_SECRET=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

GOOGLE_CLIENT_ID=

OTP_EXPIRE_MINUTES=10
OTP_MAX_ATTEMPTS=5
EMAIL_OTP_DEBUG=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=School ERP
SMTP_USE_TLS=true

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
